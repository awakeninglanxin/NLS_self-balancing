<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp"
    android:background="#0a0a14">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:layout_marginBottom="12dp">
        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="NLS 动态平衡仪 v7.12"
            android:textColor="#00e5a0"
            android:textSize="18sp"
            android:textStyle="bold" />
        <TextView
            android:id="@+id/calBtn"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="📐 校准"
            android:textColor="#7c4dff"
            android:textSize="13sp"
            android:paddingHorizontal="8dp"
            android:paddingVertical="4dp"
            android:clickable="true"
            android:focusable="true"
            android:background="?attr/selectableItemBackground" />
    </LinearLayout>

    <!-- Status Bar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="8dp"
        android:background="#111122"
        android:layout_marginBottom="8dp">

        <View
            android:id="@+id/statusDot"
            android:layout_width="10dp"
            android:layout_height="10dp"
            android:background="#ff4444"
            android:layout_marginEnd="8dp" />

        <TextView
            android:id="@+id/statusText"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="未连接"
            android:textColor="#aaa"
            android:textSize="13sp" />

        <TextView
            android:id="@+id/connectBtn"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="连接手环"
            android:textColor="#00e5a0"
            android:textSize="13sp"
            android:padding="6dp"
            android:clickable="true"
            android:focusable="true"
            android:background="?attr/selectableItemBackground" />
    </LinearLayout>

    <!-- Round & Algorithm -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:orientation="horizontal"
        android:paddingTop="8dp"
        android:paddingBottom="8dp">

        <TextView
            android:id="@+id/roundText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="第0轮"
            android:textColor="#4488ff"
            android:textSize="16sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/algoText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text=""
            android:textColor="#ffaa00"
            android:textSize="13sp"
            android:layout_marginStart="16dp" />
    </LinearLayout>

    <!-- Progress -->
    <ProgressBar
        android:id="@+id/progress"
        style="@style/Widget.AppCompat.ProgressBar.Horizontal"
        android:layout_width="match_parent"
        android:layout_height="6dp"
        android:max="18"
        android:progress="0"
        android:layout_marginTop="4dp"
        android:layout_marginBottom="4dp" />

    <!-- Tab Buttons -->
    <LinearLayout
        android:id="@+id/tabRow"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:layout_marginTop="2dp"
        android:layout_marginBottom="2dp"
        android:visibility="gone">

        <TextView android:id="@+id/tabRadar" android:text="☯ 五行"
            android:textColor="#00e5a0" android:textSize="11sp"
            android:paddingHorizontal="10dp" android:paddingVertical="4dp"
            android:background="#112222"
            android:clickable="true" android:focusable="true"
            android:layout_marginEnd="2dp" />

        <TextView android:id="@+id/tabBands" android:text="📊 偏差"
            android:textColor="#888" android:textSize="11sp"
            android:paddingHorizontal="10dp" android:paddingVertical="4dp"
            android:background="#111122"
            android:clickable="true" android:focusable="true"
            android:layout_marginEnd="2dp" />

        <TextView android:id="@+id/tabRidge" android:text="📈 脊线"
            android:textColor="#888" android:textSize="11sp"
            android:paddingHorizontal="10dp" android:paddingVertical="4dp"
            android:background="#111122"
            android:clickable="true" android:focusable="true" />
    </LinearLayout>

    <!-- Chart Area -->
    <FrameLayout
        android:id="@+id/chartContainer"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="3"
        android:background="#0d0d1a"
        android:visibility="gone" />

    <!-- Scan Results -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="⚠ 频段偏差"
        android:textColor="#888"
        android:textSize="11sp"
        android:paddingTop="4dp"
        android:paddingBottom="4dp" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="3"
        android:background="#0d0d1a">

        <LinearLayout
            android:id="@+id/bandsContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="6dp" />
    </ScrollView>

    <!-- Log -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="📋 运行日志"
        android:textColor="#888"
        android:textSize="11sp"
        android:paddingTop="4dp"
        android:paddingBottom="4dp" />

    <ScrollView
        android:id="@+id/logScroll"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="2"
        android:background="#0d0d1a">

        <LinearLayout
            android:id="@+id/logContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="4dp" />
    </ScrollView>

    <!-- Buttons -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:paddingTop="8dp">

        <TextView
            android:id="@+id/balanceBtn"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="▶ 启动平衡"
            android:textColor="#fff"
            android:textSize="15sp"
            android:gravity="center"
            android:padding="14dp"
            android:background="#00aa55"
            android:clickable="true"
            android:focusable="true"
            android:layout_marginEnd="6dp" />

        <TextView
            android:id="@+id/stopBtn"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="⏹ 停止"
            android:textColor="#fff"
            android:textSize="15sp"
            android:gravity="center"
            android:padding="14dp"
            android:background="#aa3333"
            android:clickable="true"
            android:focusable="true"
            android:layout_marginStart="6dp" />
    </LinearLayout>
</LinearLayout>
