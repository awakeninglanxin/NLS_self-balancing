<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="12dp"
    android:background="#0a0a14">

    <!-- Header -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="NLS 九维平衡仪 v7.28"
        android:textColor="#00e5a0"
        android:textSize="18sp"
        android:textStyle="bold"
        android:layout_marginBottom="8dp" />

    <!-- Status Bar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="6dp"
        android:background="#111122"
        android:layout_marginBottom="6dp">

        <View
            android:id="@+id/statusDot"
            android:layout_width="10dp"
            android:layout_height="10dp"
            android:background="#ff4444"
            android:layout_marginEnd="6dp" />

        <TextView
            android:id="@+id/statusText"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="未连接"
            android:textColor="#aaa"
            android:textSize="12sp" />

        <TextView
            android:id="@+id/calBtn"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="📐 校准"
            android:textColor="#7c4dff"
            android:textSize="12sp"
            android:paddingHorizontal="4dp"
            android:clickable="true"
            android:focusable="true"
            android:layout_marginEnd="4dp" />

        <TextView
            android:id="@+id/exportBtn"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="💾"
            android:textColor="#ffdd00"
            android:textSize="14sp"
            android:paddingHorizontal="4dp"
            android:clickable="true"
            android:focusable="true"
            android:layout_marginEnd="4dp" />

        <TextView
            android:id="@+id/connectBtn"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="连接"
            android:textColor="#00e5a0"
            android:textSize="12sp"
            android:paddingHorizontal="4dp"
            android:clickable="true"
            android:focusable="true"
            android:background="?attr/selectableItemBackground" />
    </LinearLayout>

    <!-- Round & Algo -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:orientation="horizontal"
        android:paddingTop="4dp"
        android:paddingBottom="4dp">

        <TextView
            android:id="@+id/roundText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="待校准"
            android:textColor="#4488ff"
            android:textSize="14sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/algoText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text=""
            android:textColor="#ffaa00"
            android:textSize="12sp"
            android:layout_marginStart="12dp" />
    </LinearLayout>

    <!-- Progress -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginTop="2dp">
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="⚡治疗周期 "
            android:textColor="#888"
            android:textSize="10sp" />
        <SeekBar
            android:id="@+id/speedSlider"
            android:layout_width="0dp"
            android:layout_height="20dp"
            android:layout_weight="1"
            android:max="11"
            android:progress="0"
            android:thumbTint="#7c4dff" />
        <TextView
            android:id="@+id/speedLabel"
            android:layout_width="32dp"
            android:layout_height="wrap_content"
            android:text="×1"
            android:textColor="#aaa"
            android:textSize="10sp"
            android:gravity="end" />
    </LinearLayout>

    <ProgressBar
        android:id="@+id/progress"
        style="@style/Widget.AppCompat.ProgressBar.Horizontal"
        android:layout_width="match_parent"
        android:layout_height="4dp"
        android:max="18"
        android:progress="0"
        android:layout_marginTop="2dp"
        android:layout_marginBottom="2dp" />

    <!-- Tab+Chart (views added in Kotlin) -->
    <LinearLayout
        android:id="@+id/tabHost"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="3"
        android:orientation="vertical" />

    <!-- Log -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="📋 日志"
        android:textColor="#666"
        android:textSize="10sp"
        android:paddingTop="2dp"
        android:paddingBottom="2dp" />

    <ScrollView
        android:id="@+id/logScroll"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="2"
        android:background="#0d0d1a">

        <LinearLayout
            android:id="@+id/logContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="4dp" />
    </ScrollView>

    <!-- Buttons -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:paddingTop="6dp">

        <TextView
            android:id="@+id/balanceBtn"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="▶ 启动平衡"
            android:textColor="#fff"
            android:textSize="14sp"
            android:gravity="center"
            android:padding="12dp"
            android:background="#00aa55"
            android:clickable="true"
            android:focusable="true"
            android:layout_marginEnd="4dp" />

        <TextView
            android:id="@+id/originalBtn"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="0.55"
            android:text="🔗原版"
            android:textColor="#fff"
            android:textSize="11sp"
            android:gravity="center"
            android:padding="10dp"
            android:background="#226644"
            android:clickable="true"
            android:focusable="true"
            android:layout_marginEnd="4dp" />

        <TextView
            android:id="@+id/stopBtn"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="⏹ 停止"
            android:textColor="#fff"
            android:textSize="14sp"
            android:gravity="center"
            android:padding="12dp"
            android:background="#aa3333"
            android:clickable="true"
            android:focusable="true"
            android:layout_marginStart="4dp" />
    </LinearLayout>

    <!-- 后台保活提示 -->
    <TextView android:id="@+id/bgTip" android:layout_width="match_parent"
        android:layout_height="wrap_content" android:gravity="center"
        android:text="🔋 已在后台保活 · 息屏不断电"
        android:textColor="#2fd39a" android:textSize="13sp"
        android:visibility="gone" android:layout_marginTop="4dp"/>

</LinearLayout>
